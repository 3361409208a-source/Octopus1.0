{
  "name": "octopus",
  "version": "0.1.0",
  "description": "八爪鱼 - AI终端管理桌面宠物",
  "main": "dist/main/index.js",
  "scripts": {
    "dev": "npm run build:ts && concurrently \"npm run watch:ts\" \"npm run dev:electron\"",
    "build:ts": "tsc",
    "watch:ts": "tsc -w",
    "dev:electron": "wait-on dist/main/index.js && electron .",
    "build": "npm run build:ts && npm run build:renderer",
    "build:renderer": "vite build",
    "preview": "vite preview"
  },
  "dependencies": {
    "electron": "^28.0.0",
    "node-pty": "^1.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@vitejs/plugin-react": "^4.2.0",
    "concurrently": "^8.2.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "wait-on": "^7.2.0"
  }
}
